APP_NAME=TaxSage AI
APP_ENV=dev
APP_VERSION=0.1.0
LOG_LEVEL=INFO

API_PREFIX=/api/v1
CORS_ORIGINS=*

DATABASE_URL=postgresql+psycopg2://taxsage:taxsage@localhost:5432/taxsage
# Local Redis default. For Upstash in Codespaces, replace with your rediss:// URL.
REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
